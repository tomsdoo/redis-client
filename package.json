{
  "name": "@tomsd/redis-client",
  "version": "1.4.0",
  "description": "It's a wrapper of ioredis.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "biome check",
    "prepare": "husky",
    "start-redis": "docker compose up -d",
    "stop-redis": "docker compose down",
    "serve:doc": "mdbook --serve --directory docs",
    "test": "vitest --project node",
    "test:local": "vitest --project local"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "npm run lint"
    ],
    "__test__/**/*.ts": [
      "npm run lint"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomsdoo/redis-client.git"
  },
  "keywords": [
    "redis"
  ],
  "author": "tom",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tomsdoo/redis-client/issues"
  },
  "homepage": "https://github.com/tomsdoo/redis-client#readme",
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@tomsd/md-book": "2.0.8",
    "@types/node": "25.6.0",
    "@types/uuid": "11.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "ts-node": "10.9.2",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "ioredis": "5.10.1",
    "uuid": "14.0.0"
  }
}
